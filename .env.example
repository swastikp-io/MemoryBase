# MemoryBase Environment Configuration
# Copy this to .env and fill in your values

# OpenRouter (AI Model Provider)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web Search API
WEB_SEARCH_API=your-web-search-api-key




# Deep Research & Reliability Configs
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_DELAY_MS=2000
PRIMARY_RESEARCH_MODEL=openai/gpt-oss-120b:free
FALLBACK_RESEARCH_MODELS=google/gemma-3-27b-it:free,google/gemma-4-26b-a4b-it:free
WEB_SEARCH_MAX_RETRIES=2
WEB_SEARCH_TIMEOUT_MS=10000
TITLE_GENERATION_MODEL=openai/gpt-oss-120b:free
TITLE_GENERATION_FALLBACK_MODEL=google/gemma-3-27b-it:free

# Wikipedia Knowledge Integration Configs
ENABLE_WIKIPEDIA_SEARCH=true
ENABLE_WIKIPEDIA_ENRICHMENT=true
WIKIPEDIA_LANGUAGE=en
WIKIPEDIA_CACHE_TTL=3600
WIKIPEDIA_REQUEST_TIMEOUT=10000
